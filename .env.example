# Database (local Postgres example)
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/restaurant?schema=public"
# Optional: used by transfer/verify scripts when restoring from SQLite
POSTGRES_RESTORE_URL="postgresql://postgres:your-password@localhost:5432/restaurant?schema=public"

# Admin API key – used to protect admin routes. Set a strong random string.
# Example: openssl rand -hex 32
ADMIN_API_KEY="change-me-to-a-strong-random-secret"

# Shopify Storefront API
# Found in Shopify Admin → Apps → Storefront API → Manage access tokens
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"

# Shopify webhook secret — required for payment status updates.
# Generate in Shopify Admin → Settings → Notifications → Webhooks.
# Subscribe to: orders/paid, orders/cancelled, checkouts/delete
# and set the endpoint to https://your-domain.com/api/webhooks/shopify
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret"

# Email and public support contact
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@e-restaurant.com"
CONTACT_FORM_TO_EMAIL="support@e-restaurant.com"
SUPPORT_EMAIL="hello@e-restaurant.com"
SUPPORT_PHONE="+44 20 0000 0000"
SUPPORT_HOURS="Monday to Sunday, 11:00 to 22:30"
SERVICE_AREA="London service area with online ordering and admin-side operations controls."

# Public app URL used for customer links in email templates
APP_BASE_URL="http://localhost:3000"
