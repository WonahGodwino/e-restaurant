# Database
DATABASE_URL="file:./prisma/dev.db"

# Admin API key – used to protect admin routes. Set a strong random string.
# Example: openssl rand -hex 32
ADMIN_API_KEY="change-me-to-a-strong-random-secret"

# Shopify Storefront API
# Found in Shopify Admin → Apps → Storefront API → Manage access tokens
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your-storefront-access-token"

# Optional: Shopify webhook secret (for payment confirmation webhooks)
# SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"
